{
  "sectionId": "triphthongs",
  "title": {
    "es": "De los Triptongos",
    "en": "Triphthongs",
    "fr": "Les Triphtongues"
  },
  "introduction": {
    "es": "Los triptongos son combinaciones de tres vocales que mantienen su sonido continuo."
  },
  "note": {
    "es": "Estas y semejantes combinaciones se hallarán en gran número y variedad al registrar la conjugación de los verbos regulares en su voz pasiva."
  },
