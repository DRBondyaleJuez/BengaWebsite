  "conceptCards": [
    {
      "title": "Patrón mi- Común",
      "description": "Aunque esta clase comienza con dos prefijos diferentes (bo-, ba-), ambos convergen a 'mi' en plural"
    },
    {
      "title": "Sustantivos Concretos",
