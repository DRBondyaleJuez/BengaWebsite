    }
  ],
  "conceptCards": [
    {
      "title": "Ausencia de Cambio",
      "description": "La séptima clase no cambia de forma entre singular y plural, lo que simplifica su uso"
    },
    {
      "title": "Numerosa en Ejemplos",
      "description": "Contiene la mayor cantidad de sustantivos individuales, aunque no se transforman"
    },
    {
      "title": "Diversidad Temática",
      "description": "Abarca una amplia gama de sustantivos: animales, objetos, conceptos abstractos y palabras loanwords"
    },
    {
      "title": "Importancia Conceptual",
      "description": "Muchas palabras invariables son fundamentales para la comunicación cotidiana"
    }
  ],
  "practiceNotes": {
    "es": "La séptima clase contiene la mayoría de sustantivos individuales en Benga. Como no hay cambios de forma, la tarea es memorizar qué palabras completamente. Observa que incluye palabras derivadas del español (fala, pago, sago) y palabras completamente benga (ngama, ndaga)."
  }
