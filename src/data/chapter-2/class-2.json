  "concordanceRules": [
    {
      "label": "Singular",
      "article": "i-, di-",
      "adjective": "-i, -a",
      "example": "i-baké i-nene"
    },
    {
      "label": "Plural",
      "article": "ma-",
      "adjective": "-ma, -me",
      "example": "ma-baké ma-nene"
    }
  ],
  "conceptCards": [
    {
      "title": "Clase Más Numerosa",
      "description": "La segunda clase contiene la mayor cantidad de sustantivos en la lengua Benga"
    },
    {
      "title": "Patrón ma-",
      "description": "Independientemente de si el singular comienza con 'i' o 'di', el plural siempre cambia a 'ma'"
    },
    {
      "title": "Importancia Gramatical",
      "description": "La mayoría de derivados nominales terminan en esta clase, haciéndola fundamental para la formación de vocabulario"
    }
  ],
  "practiceNotes": {
    "es": "Esta es la clase más importante para dominar. Muchos de estos sustantivos son palabras comunes y esenciales. Practica la transformación i/di → ma hasta que sea automática."
  }
