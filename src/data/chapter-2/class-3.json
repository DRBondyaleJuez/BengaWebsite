  "concordanceRules": [
    {
      "label": "Singular con u-",
      "article": "u-, w-",
      "adjective": "-u, -o",
      "example": "u-aha u-nene"
    },
    {
      "label": "Singular con mú-",
      "article": "mú-",
      "adjective": "-u, -i",
      "example": "mú-adi mú-nene"
    },
    {
      "label": "Plural",
      "article": "me-, mi-",
      "adjective": "-me, -mi",
      "example": "me-aha me-nene"
    }
  ],
  "conceptCards": [
    {
      "title": "Dos Raíces Singulares",
      "description": "Esta clase tiene tanto sustantivos que comienzan con 'u' como con 'mú', lo que la hace única"
    },
    {
      "title": "Cambio Bifurcado",
      "description": "Ambas raíces convergen en 'me' o 'mi' en plural, creando una clase nominal coherente"
    },
    {
      "title": "Palabras de Familia",
      "description": "Muchos términos de parentesco pertenecen a esta clase"
    }
  ],
  "practiceNotes": {
    "es": "Observa cómo la pronunciación de 'u' como 'w' es importante en esta clase. La tercera clase es especialmente importante para vocabulario de familia y naturaleza."
  }
