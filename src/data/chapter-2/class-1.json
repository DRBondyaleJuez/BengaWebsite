  "concordanceRules": [
    {
      "label": "Singular",
      "article": "e-",
      "adjective": "-a, -e",
      "example": "e-janganangobo e-nene"
    },
    {
      "label": "Plural",
      "article": "be-",
      "adjective": "-be, -nene",
      "example": "be-janganangobo be-nene"
    }
  ],
  "conceptCards": [
    {
      "title": "Patrón de Cambio",
      "description": "La vocal inicial 'e' en singular se reemplaza por el prefijo 'be' en plural"
    },
    {
      "title": "Coherencia de Prefijo",
      "description": "Una vez que el nombre adopta 'be' en plural, todos los adjuntos concordantes también adoptan 'be'"
    },
    {
      "title": "Variantes con Y",
      "description": "Los nombres que comienzan con 'y' (que funciona como consonante) también siguen esta regla, pasando a 'bi' en plural"
    }
  ],
  "practiceNotes": {
    "es": "Memoriza el cambio e → be como una transformación sistemática. Esta clase es fundamental para comprender los patrones de concordancia nominal en Benga."
  }
